# jeeves-unchained — secrets and environment variables.
# Copy to `.env` locally; in CI these live in GitHub Secrets and are injected
# through workflow env: blocks.

# --- Phase 2: Research ---
NVIDIA_API_KEY=              # Kimi K2.5 on NVIDIA NIM (research orchestrator)
SERPER_API_KEY=              # Serper.dev (Google SERP)
TAVILY_API_KEY=              # Tavily search + extract
EXA_API_KEY=                 # Exa neural semantic search
GOOGLE_API_KEY=              # Gemini grounded search (P2) + Gmail API (P4)

# --- Phase 3: Write ---
GROQ_API_KEY=                # Groq Llama 3.3 70B (Jeeves voice)
GMAIL_APP_PASSWORD=          # SMTP send (smtp.gmail.com:465)

# --- Phase 4: Correspondence ---
# Inline JSON of the Gmail OAuth user token (refresh_token, client_id,
# client_secret, token_uri, scopes). Mint once locally with
# `python scripts/gmail_auth.py --credentials ~/Downloads/credentials.json`
# and paste the output into this var / the GMAIL_OAUTH_TOKEN_JSON secret.
GMAIL_OAUTH_TOKEN_JSON=

# --- Shared ---
GITHUB_TOKEN=                # Auto-provided in GitHub Actions; set locally for session commits
GITHUB_REPOSITORY=mmmichaelllang/jeeves-unchained

# --- Model overrides (optional) ---
KIMI_MODEL_ID=moonshotai/kimi-k2.6
GROQ_MODEL_ID=llama-3.3-70b-versatile

# --- Optional: TinyFish managed extractor (sprint-18 canary) ---
# Silent disable when blank — fetch chain falls through to playwright as
# before. Two opt-in flags gate active use:
#   JEEVES_TINYFISH_SHADOW=1  → run TinyFish in parallel with playwright,
#                                log both to sessions/shadow-tinyfish-*.jsonl
#   JEEVES_USE_TINYFISH=1     → register tinyfish_extract as an agent tool
#                                AND insert it into the enrichment fetch
#                                chain ahead of playwright.
TINYFISH_API_KEY=
JEEVES_TINYFISH_SHADOW=
JEEVES_USE_TINYFISH=

# --- Recipient ---
JEEVES_RECIPIENT_EMAIL=lang.mc@gmail.com
